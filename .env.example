# Database
# Use 5433 if local Postgres is running on 5432 (docker-compose maps 5433:5432)
DATABASE_URL=postgresql+asyncpg://tradeai:tradeai_dev@localhost:5433/tradeai

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MODEL_PROD=claude-sonnet-4-6
DAILY_BUDGET_USD=1.00

# App
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
